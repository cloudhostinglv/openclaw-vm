# OpenClaw per-client VM — environment template.
# Copy to `.env` (lives at ~/.openclaw/.env, bind-mounted into the container) and fill
# in. The real `.env` is gitignored and injected per-client at provision time
# (see autoinstall-snippet.yaml). NEVER commit a real .env.
#
# These vars are referenced by openclaw.json as ${VAR} secret refs. OpenClaw resolves
# them at gateway start, so the keys never sit in the JSON config in plaintext.

# ── avots.ai backend (each client uses their OWN key) ────────────────────────
# Key format: av_mcp_<...>. Wired into openclaw.json as
#   models.providers.avots.apiKey = ${AVOTS_API_KEY}
# Base URL + model id are set in openclaw.json (https://api.avots.ai/openai/v1,
# model anthropic/claude-opus-4.8). The lazy alias `claude` also resolves on avots,
# but we pin the fully-qualified id for reproducibility.
AVOTS_API_KEY=av_mcp_REPLACE_ME

# ── Gateway auth token ───────────────────────────────────────────────────────
# Defense-in-depth even though the gateway binds to loopback only. UNIQUE per VM.
# Generate once:  openssl rand -hex 32
# Referenced by openclaw.json gateway.auth.token = ${OPENCLAW_GATEWAY_TOKEN}
# and exported into the container env by docker-compose.yml.
OPENCLAW_GATEWAY_TOKEN=REPLACE_ME_GATEWAY_TOKEN

# ── Messaging channel (OUTBOUND-ONLY long-polling; pick ONE) ──────────────────
# Default example is Telegram. Replace with the client's chosen channel and update
# the matching `channels.*` block in openclaw.json. allowFrom MUST be set so the
# agent only answers its owner — an open agent on an RCE-capable VM is a takeover.
#
# Telegram: create a bot via @BotFather, paste the token. TELEGRAM_OWNER_ID is the
# numeric user id the agent will accept (get it from @userinfobot).
TELEGRAM_BOT_TOKEN=REPLACE_ME_TELEGRAM_BOT_TOKEN
TELEGRAM_OWNER_ID=REPLACE_ME_NUMERIC_TELEGRAM_USER_ID

# Examples for other outbound-only channels (uncomment + wire into openclaw.json):
# WHATSAPP_*=...
# DISCORD_BOT_TOKEN=...

# ── Host bind-mount locations (used by docker-compose.yml) ───────────────────
# Where ~/.openclaw lives on the host. Provisioning normally sets these to the
# service user's home so state survives re-bakes.
# OPENCLAW_CONFIG_DIR=/home/openclaw/.openclaw
# OPENCLAW_WORKSPACE_DIR=/home/openclaw/.openclaw/workspace
# OPENCLAW_AUTH_PROFILE_SECRET_DIR=/home/openclaw/.openclaw-auth-profile-secrets

# ── Misc ─────────────────────────────────────────────────────────────────────
# OPENCLAW_TZ=Europe/Riga
# OPENCLAW_GATEWAY_PORT=18789   # host loopback port; container port is fixed at 18789
